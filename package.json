{
  "name": "task-tracker-backend",
  "version": "1.0.0",
  "description": "Task Tracker SaaS Backend - Multi-tenant with Dynamic Permissions",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env server.js",
    "dev": "node --env-file=.env --watch server.js",
    "seed": "node --env-file=.env src/seed.js",
    "seed:admin": "node --env-file=.env src/seeders/adminSeeder.js",
    "seed:users": "node --env-file=.env src/seeders/mockUsersSeeder.js",
    "fix:owner": "node --env-file=.env src/seeders/fixOwnerPermissions.js",
    "fix:subscription": "node --env-file=.env src/scripts/fixSubscription.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "npm test -- --watch",
    "test:coverage": "npm test -- --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [
    "task-tracker",
    "saas",
    "multi-tenant",
    "permissions",
    "mern"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.21.2",
    "mongoose": "^8.9.5",
    "dotenv": "^16.4.7",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.5",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "zod": "^3.24.1",
    "socket.io": "^4.8.1",
    "ioredis": "^5.4.2",
    "bullmq": "^5.34.8",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.1",
    "resend": "^4.1.2",
    "razorpay": "^2.9.5",
    "multer": "^2.0.0",
    "winston": "^3.17.0",
    "uuid": "^11.0.5",
    "slugify": "^1.6.6",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "mongoose-paginate-v2": "^1.8.5",
    "express-mongo-sanitize": "^2.2.0",
    "hpp": "^0.2.3",
    "cookie-parser": "^1.4.7"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "mongodb-memory-server": "^10.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
